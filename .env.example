# Copie este arquivo para .env e preencha os valores.
# .env já está no .gitignore — não commitar.

# ============================================================================
# OpenAI — usado em caption_gen, competitor_intel, image_engine, agente WA
# ============================================================================
OPENAI_API_KEY=sk-...

# Modelos (opcionais — defaults razoáveis embarcados no código)
# HAUS_CAPTION_MODEL=gpt-4.1-mini
# HAUS_COMPETITOR_MODEL=gpt-4.1-mini
# HAUS_IMAGE_MODEL=gpt-image-1
# HAUS_WA_AGENT_MODEL=gpt-4.1-mini

# ============================================================================
# Apify — usado em competitor_intel pra scrape de Instagram
# ============================================================================
APIFY_TOKEN=apify_api_...

# ============================================================================
# Evolution API — WhatsApp transport (MVP/demo)
# ============================================================================
EVOLUTION_API_URL=https://evo.seudominio.com
EVOLUTION_INSTANCE_NAME=haus-demo
EVOLUTION_API_KEY=...
# URL publica que a Evolution chama. Alternativa: defina HAUS_PUBLIC_URL sem /webhook/wa.
EVOLUTION_WEBHOOK_URL=https://painel.seudominio.com/webhook/wa
# HAUS_PUBLIC_URL=https://painel.seudominio.com

# ============================================================================
# Z-API — WhatsApp transport (futuro, quando migrar pra produção)
# ============================================================================
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=
